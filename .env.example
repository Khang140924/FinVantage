# Cấu hình Môi trường AWS (AWS Environment Configuration)
AWS_REGION=ap-southeast-1
S3_RAW_BUCKET_NAME=finvantage-raw-invoices-dev


# Cấu hình Cơ sở dữ liệu PostgreSQL (PostgreSQL Database Configuration)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finvantage
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL=false

# Cấu hình Redis (Redis Cache Configuration)
REDIS_URL=redis://localhost:6379

# Cấu hình ứng dụng khác (App Configurations)
DEBUG=true
