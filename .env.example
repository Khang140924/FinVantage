# FinVantage local configuration template
# Copy this file to .env and replace every your_* value with your own setting.
# Never commit .env, AWS credentials, Cognito secrets, database passwords, or tokens.

# Application and Auth BFF
NODE_ENV=development
AUTH_SERVER_PORT=4000
SESSION_SECRET=replace_with_a_long_random_value
DEBUG=false

# Local development: set true to bypass Cognito with the built-in development user.
# Never enable mock authentication in production.
USE_MOCK_AUTH=true

# Amazon Cognito (required when USE_MOCK_AUTH=false)
COGNITO_ISSUER=https://cognito-idp.your-region.amazonaws.com/your_user_pool_id
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_CLIENT_SECRET=your_cognito_client_secret
COGNITO_DOMAIN=https://your-domain.auth.your-region.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:5174/auth/callback
COGNITO_LOGOUT_URI=http://localhost:5174/
COGNITO_SCOPES=openid email profile

# AWS services. Prefer an AWS CLI profile instead of placing access keys here.
AWS_REGION=your_aws_region
AWS_REGION_NAME=your_aws_region
AWS_PROFILE=finvantage-local-dev
S3_RAW_BUCKET_NAME=your_private_invoice_bucket
S3_BUCKET_NAME=your_private_invoice_bucket
PROFILE_AVATAR_BUCKET_NAME=your_private_avatar_bucket
BEDROCK_MODEL_ID=your_bedrock_model_id
USE_MOCK_AI=true
SNS_BUDGET_ALERTS_TOPIC_ARN=your_sns_topic_arn_or_leave_empty_for_local

# PostgreSQL / Aurora through RDS Proxy in AWS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finvantage
DB_USER=your_postgres_user
DB_PASSWORD=your_local_database_password
DB_SSL=false
RDS_PROXY_ENDPOINT=

# Redis
REDIS_URL=redis://localhost:6379
