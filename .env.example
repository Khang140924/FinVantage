# FinVantage safe local template. Never commit a populated .env file.
# Production values belong in the deployment environment and Secrets Manager.

# Runtime and Serverless stage
NODE_ENV=development
APP_STAGE=dev
STAGE=dev
AUTH_SERVER_PORT=4000
LOG_LEVEL=info
DEBUG=false
SERVERLESS_DEPLOYMENT_BUCKET=finvantage-serverless-artifacts-dev
PRIVATE_SUBNET_IDS=
LAMBDA_SECURITY_GROUP_IDS=
KMS_KEY_ARN=
APP_SECRET_ARN=
REDIS_URL_SECRET_ARN=

# Authentication. VITE_AUTH_MODE must match USE_MOCK_AUTH.
USE_MOCK_AUTH=true
SESSION_SECRET=replace_with_a_random_value_of_at_least_32_characters
COGNITO_ISSUER=https://cognito-idp.region-code.amazonaws.com/pool-id
COGNITO_USER_POOL_ID=region-code_pool-id
COGNITO_CLIENT_ID=replace_with_cognito_client_id
COGNITO_CLIENT_SECRET=replace_in_a_secure_environment
COGNITO_DOMAIN=https://domain-prefix.auth.region-code.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:5174/auth/callback
COGNITO_LOGOUT_URI=http://localhost:5174/
COGNITO_SCOPES=openid email profile
AUTH_SESSION_REDIS_URL=
AUTH_SESSION_TTL_SECONDS=86400

# AWS services. Profile names are local-only and are never passed to Lambda.
AWS_REGION=ap-southeast-1
AWS_REGION_NAME=ap-southeast-1
AWS_PROFILE=finvantage-local-dev
S3_RAW_BUCKET_NAME=replace_with_private_invoice_bucket
S3_BUCKET_NAME=replace_with_private_invoice_bucket
PROFILE_AVATAR_BUCKET_NAME=replace_with_private_avatar_bucket
SNS_BUDGET_ALERTS_TOPIC_ARN=
USE_MOCK_AI=true
BEDROCK_AWS_PROFILE=finvantage-bedrock-cross
BEDROCK_AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_ROLE_ARN=
BEDROCK_ROLE_SESSION_NAME=finvantage-bedrock
BEDROCK_EXTERNAL_ID=

# PostgreSQL local values; production uses RDS_PROXY_ENDPOINT + DB_SECRET_ARN.
RDS_PROXY_ENDPOINT=
DB_HOST=localhost
DB_PORT=5433
DB_NAME=finvantage
DB_USER=replace_with_local_database_user
DB_PASSWORD=replace_with_local_database_password
DB_SECRET_ARN=
DB_ADMIN_SECRET_ARN=
DB_SECRET_REGION=ap-southeast-1
DB_SSL=false
DB_SSL_CA_BASE64=
# Lambda Node.js 20+ production default is /var/runtime/ca-cert.pem.
NODE_EXTRA_CA_CERTS=
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=25000
DB_IDLE_TRANSACTION_TIMEOUT_MS=15000

# Shared Redis/Valkey. Production must use a rediss:// URL.
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=finvantage
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_COMMAND_TIMEOUT_MS=3000
REDIS_MAX_RECONNECT_ATTEMPTS=3
REDIS_RECONNECT_BASE_DELAY_MS=100
REDIS_RECONNECT_MAX_DELAY_MS=1000

# One explicit browser origin; never use '*'.
API_ALLOWED_ORIGIN=http://localhost:5174
