AWS_REGION=ap-southeast-1
AWS_REGION_NAME=ap-southeast-1
S3_RAW_BUCKET_NAME=finvantage-raw-invoices-dev
S3_BUCKET_NAME=finvantage-raw-invoices-dev
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

DB_HOST=localhost
DB_PORT=5432
DB_NAME=finvantage
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
# AWS production: set this to the Aurora/PostgreSQL RDS Proxy endpoint.
RDS_PROXY_ENDPOINT=

REDIS_URL=redis://localhost:6379
USE_MOCK_AI=true
NODE_ENV=development

# AWS-only account infrastructure
PROFILE_AVATAR_BUCKET_NAME=finvantage-raw-invoices-dev
SNS_BUDGET_ALERTS_TOPIC_ARN=

# --- AWS Cognito (authentication) ---
# User pool issuer (region ap-southeast-2 in your setup)
COGNITO_ISSUER=https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_w5VOUmdXq
COGNITO_USER_POOL_ID=ap-southeast-2_w5VOUmdXq
COGNITO_CLIENT_ID=2hs9fmv5n769u1oit0022hisjf
# Secret of the Cognito app client (confidential client). Keep this safe.
COGNITO_CLIENT_SECRET=
# Hosted UI domain, used for logout, e.g. https://<your-pool>.auth.ap-southeast-2.amazoncognito.com
COGNITO_DOMAIN=
# Callback and logout URLs must match the Cognito app client configuration
COGNITO_REDIRECT_URI=http://localhost:5174/auth/callback
COGNITO_LOGOUT_URI=http://localhost:5174/
COGNITO_SCOPES=openid email profile

# Auth BFF (Express + openid-client) settings
AUTH_SERVER_PORT=4000
SESSION_SECRET=change-me-to-a-random-string

# Local mock auth: skips Cognito discovery and accepts only the built-in mock token.
# Never enable this in production.
USE_MOCK_AUTH=false

# The custom FinVantage credential form requires ALLOW_USER_PASSWORD_AUTH on
# the Cognito app client. Hosted UI login remains available as a fallback.
